<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    android:background="@drawable/bg_campaign_rules_item"
    android:orientation="horizontal"
    android:paddingHorizontal="10dp"
    android:paddingVertical="8dp">

    <View
        android:layout_width="4dp"
        android:layout_height="4dp"
        android:layout_marginTop="7dp"
        android:layout_marginEnd="8dp"
        android:background="@drawable/bg_campaign_rule_bullet" />

    <TextView
        android:id="@+id/campaign_rule_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:lineSpacingMultiplier="1.45"
        android:textColor="@color/portal_text_primary"
        android:textSize="13sp" />
</LinearLayout>
